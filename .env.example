# Connexion MongoDB (obligatoire)
# En local sans Docker :
MONGO_URI=mongodb://127.0.0.1:27017/smr-planner
# Avec Docker Compose, l'app utilise automatiquement mongodb://mongo:27017/smr-planner

# Secret JWT pour l'authentification (obligatoire en production)
JWT_SECRET=changez_moi_en_production

# Limitation de débit (optionnel)
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX=100
# RATE_LIMIT_AUTH_MAX=20
# RATE_LIMIT_PLANNING_MAX=30

# Derrière Docker / nginx : activer pour le rate-limit par IP réelle
# TRUST_PROXY=true

# Port du serveur (optionnel)
PORT=4000

# URL publique pour les liens iCal (optionnel)
# PUBLIC_BASE_URL=https://votre-domaine.fr
